# RescueRoute environment variables. Copy to .env.local and fill in.

# Supabase (client-side, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (server-only — NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (client-side token) — NOT REQUIRED, using free OpenStreetMap tiles
# NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAI (server-only)
OPENAI_API_KEY=

# Default map center (used as fallback when no location can be resolved)
NEXT_PUBLIC_DEFAULT_MAP_LAT=40.7128
NEXT_PUBLIC_DEFAULT_MAP_LNG=-74.006
